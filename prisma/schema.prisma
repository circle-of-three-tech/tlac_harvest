generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  password          String
  role              Role               @default(EVANGELIST)
  phone             String?
  gender            Gender?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  lastActivity      DateTime           @default(now())
  noOfSoulsTarget   Int?               @default(0)
  adminPhones       AdminPhone[]
  announcements     Announcement[]
  auditLogs         AuditLog[]
  addedLeads        Lead[]             @relation("AddedBy")
  assignedLeads     Lead[]             @relation("AssignedTo")
  notes             Note[]
  pushSubscriptions PushSubscription[]
  smsTemplates      SMSTemplate[]
}

model Lead {
  id               String            @id @default(cuid())
  fullName         String
  ageRange         AgeRange
  phone            String?
  address          String?
  location         String
  additionalNotes  String?
  gender           Gender            @default(MALE)
  soulState        SoulState
  status           LeadStatus        @default(NEW_LEAD)
  churchMembership ChurchMembership?
  churchName       String?
  monthsConsistent Int               @default(0)
  addedById        String
  assignedToId     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  auditLogs        AuditLog[]
  addedBy          User              @relation("AddedBy", fields: [addedById], references: [id])
  assignedTo       User?             @relation("AssignedTo", fields: [assignedToId], references: [id])
  notes            Note[]
  smsLogs          SMSLog[]
}

model Note {
  id        String   @id @default(cuid())
  content   String
  leadId    String
  userId    String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model SMSTemplate {
  id          String   @id @default(cuid())
  type        SMSType  @unique
  title       String
  content     String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation(fields: [createdById], references: [id])
}

model SMSLog {
  id             String    @id @default(cuid())
  type           SMSType
  recipientPhone String
  content        String
  status         SMSStatus @default(PENDING)
  errorMessage   String?
  leadId         String?
  createdAt      DateTime  @default(now())
  sentAt         DateTime?
  lead           Lead?     @relation(fields: [leadId], references: [id])
}

model Announcement {
  id          String     @id @default(cuid())
  title       String
  content     String
  targetRole  TargetRole
  expiryDate  DateTime
  hidden      Boolean    @default(false)
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  createdBy   User       @relation(fields: [createdById], references: [id])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AdminPhone {
  id        String   @id @default(cuid())
  phone     String
  adminId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([adminId, phone])
}

model AuditLog {
  id          String       @id @default(cuid())
  type        AuditLogType
  leadId      String
  userId      String
  fieldName   String?
  oldValue    String?
  newValue    String?
  noteContent String?
  details     Json?
  createdAt   DateTime     @default(now())
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  auth      String
  p256dh    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
}

enum Role {
  EVANGELIST
  FOLLOWUP
  ADMIN
}

enum SoulState {
  UNBELIEVER
  NEW_CONVERT
  UNCHURCHED_BELIEVER
  HUNGRY_BELIEVER
}

enum LeadStatus {
  NEW_LEAD
  FOLLOWING_UP
  CONVERTED
}

enum Gender {
  MALE
  FEMALE
}

enum AgeRange {
  UNDER_18
  AGE_18_25
  AGE_26_35
  AGE_36_45
  AGE_46_60
  ABOVE_60
}

enum ChurchMembership {
  TLAC
  KSOD
  BOTH_TLAC_AND_KSOD
  OTHERS
}

enum SMSType {
  NEW_LEAD_NOTIFICATION
  ADMIN_ALERT
  FOLLOWUP_ASSIGNMENT
  SOULSTATE_UNBELIEVER
  SOULSTATE_NEW_CONVERT
  SOULSTATE_UNCHURCHED_BELIEVER
  SOULSTATE_HUNGRY_BELIEVER
}

enum SMSStatus {
  PENDING
  SENT
  FAILED
}

enum TargetRole {
  FOLLOWUP
  EVANGELIST
  ALL
}

enum AuditLogType {
  NOTE
  FIELD_CHANGE
  SMS_SENT
  STATUS_CHANGE
  ASSIGNMENT
}
